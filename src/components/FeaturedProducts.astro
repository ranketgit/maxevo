    { name: "Gobelets en plastique clair", category: "Boissons", desc: "Adaptés aux boissons froides", image: "/images/products/gobelet-plastique.jpg" },
    { name: "Pots à glace avec couvercle", category: "Desserts", desc: "Préservation de la fraîcheur", image: "/images/products/pot-glace.jpg" },
    { name: "Assiettes biodégradables", category: "Assiettes", desc: "Résistantes et élégantes", image: "/images/products/assiettes.jpg" },
    { name: "Couverts en bois", category: "Couverts", desc: "Ergonomiques et durables", image: "/images/products/couverts.jpg" },
    { name: "Boîtes à salade transparentes", category: "Salades", desc: "Pour une présentation parfaite", image: "/images/products/salade-claire.jpg" },
    { name: "Boîtes à salade kraft", category: "Salades", desc: "Solides et pratiques", image: "/images/products/salade-kraft.jpg" },
    { name: "Boîtes à gâteau pâtissières", category: "Pâtisserie", desc: "Protectrices et haut de gamme", image: "/images/products/boite-gateau.jpg" },
    { name: "Pots à sauce hermétiques", category: "Sauces", desc: "Préserve la saveur", image: "/images/products/pot-sauce.jpg" },
    { name: "Boîtes à pâtes rondes", category: "Plats chauds", desc: "Faciles à transporter", image: "/images/products/boite-pates.jpg" },
    { name: "Emballages pour sandwichs", category: "Snacking", desc: "Présentation professionnelle", image: "/images/products/wrap-sandwich.jpg" },
    { name: "Pots pour frites", category: "Snacking", desc: "Confort de service garanti", image: "/images/products/pot-frites.jpg" },
    { name: "Boîtes thermorésistantes", category: "Plats chauds", desc: "Pour plats à emporter", image: "/images/products/boite-thermo.jpg" },
    { name: "Barquettes en aluminium", category: "Cuisson", desc: "Légères et robustes", image: "/images/products/barquette-alu.jpg" },
    { name: "Boîtes kraft rectangulaires", category: "Général", desc: "Respect de l’environnement", image: "/images/products/boite-rectangulaire.jpg" },
    { name: "Couvercles dômes", category: "Accessoires", desc: "Pour gobelets et pots à glace", image: "/images/products/couvercle-dome.jpg" },
    { name: "Couvercles plats", category: "Accessoires", desc: "Fermeture sécurisée", image: "/images/products/couvercle-plat.jpg" },
