---
// src/components/Footer.astro
---

<footer class="bg-[#333333] text-[#EFEFEF] pt-16 md:pt-20 pb-8 border-t-8 border-[#13522B] w-full">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
            
            <div class="flex flex-col">
                <a href="/" class="text-2xl md:text-3xl font-black text-white tracking-tighter mb-4 flex items-center gap-2">
                    MAXEVO<span class="text-[#E86B21]">.</span>
                </a>
                <p class="text-[#EFEFEF] opacity-80 text-sm leading-relaxed mb-6 pr-4">
                    Entreprise marocaine spécialisée dans les solutions d’emballage alimentaire jetable de haute qualité pour les professionnels de la restauration. La qualité dans chaque détail.
                </p>
                <div class="flex gap-4">
                    <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#E86B21] transition-colors">
                        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                    </a>
                    <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#E86B21] transition-colors">
                        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                </div>
            </div>

            <div class="flex flex-col">
                <h4 class="text-white font-bold text-lg mb-6 tracking-wide">Liens Rapides</h4>
                <ul class="flex flex-col gap-3">
                    <li><a href="/produits" class="text-[#EFEFEF] opacity-80 hover:opacity-100 hover:text-[#E86B21] transition-colors">Nos Produits</a></li>
                    <li><a href="/secteurs" class="text-[#EFEFEF] opacity-80 hover:opacity-100 hover:text-[#E86B21] transition-colors">Solutions par Secteur</a></li>
                    <li><a href="/a-propos" class="text-[#EFEFEF] opacity-80 hover:opacity-100 hover:text-[#E86B21] transition-colors">À propos de nous</a></li>
                    <li><a href="/processus" class="text-[#EFEFEF] opacity-80 hover:opacity-100 hover:text-[#E86B21] transition-colors">Notre Processus</a></li>
                </ul>
            </div>

            <div class="flex flex-col">
                <h4 class="text-white font-bold text-lg mb-6 tracking-wide">Contactez-nous</h4>
                <ul class="flex flex-col gap-4">
                    <li class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-[#13522B] shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span class="text-[#EFEFEF] opacity-80 text-sm leading-snug">Rue Bachir Ibrahimi Mamounia<br/>Centre B3 9 ETG 5<br/>20000 Casablanca</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-[#13522B] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        <a href="tel:+212660368985" class="text-[#EFEFEF] opacity-80 hover:opacity-100 hover:text-[#E86B21] transition-colors">+212 660-368985</a>
                    </li>
                    <li class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-[#13522B] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <a href="mailto:contact@maxevo.ma" class="text-[#EFEFEF] opacity-80 hover:opacity-100 hover:text-[#E86B21] transition-colors">contact@maxevo.ma</a>
                    </li>
                </ul>
            </div>

            <div class="flex flex-col items-start lg:items-end">
                <h4 class="text-white font-bold text-lg mb-4 tracking-wide w-full lg:text-right">Prêt à commander ?</h4>
                <p class="text-[#EFEFEF] opacity-80 text-sm mb-6 w-full lg:text-right">Obtenez un devis personnalisé pour vos besoins en emballage.</p>
                <a href="/contact" class="bg-[#E86B21] text-white px-6 py-3 rounded-xl font-medium hover:bg-[#d15f1c] transition-colors flex items-center justify-center gap-2 group w-full sm:w-auto shadow-lg">
                    Demander un devis
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
            </div>

        </div>

        <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-[#EFEFEF] opacity-50 text-sm text-center md:text-left">
                &copy; {new Date().getFullYear()} Maxevo Packaging. Tous droits réservés.
            </p>
            <div class="flex gap-4 text-sm text-[#EFEFEF] opacity-50">
                <a href="#" class="hover:text-white transition-colors">Mentions Légales</a>
                <span>|</span>
                <a href="#" class="hover:text-white transition-colors">Politique de Confidentialité</a>
            </div>
        </div>

    </div>
</footer>