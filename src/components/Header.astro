---
// src/components/Header.astro
---

<header id="main-header" class="fixed top-0 w-full z-50 transition-all duration-300 bg-transparent border-b border-transparent">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl h-20 flex items-center justify-between">
        
        <a href="/" class="flex flex-col justify-center group">
            <span class="logo-text text-2xl font-black text-white tracking-tighter leading-none flex items-baseline gap-1 transition-colors duration-300">
                MAXEVO<span class="text-[#13522B] text-3xl leading-none">.</span>
            </span>
            <span class="logo-subtext text-[10px] text-white/80 tracking-[0.2em] font-medium leading-none mt-1 transition-colors duration-300">PACKAGING</span>
        </a>

        <nav class="hidden md:flex items-center gap-8">
            <a href="#produits" class="nav-link text-white hover:text-[#E86B21] text-sm font-medium transition-colors duration-300">Nos Produits</a>
            
            <div class="relative group cursor-pointer py-6">
                <a href="#secteurs" class="nav-link text-white hover:text-[#E86B21] text-sm font-medium transition-colors duration-300 flex items-center gap-1">
                    Solutions par Secteur
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-70 group-hover:rotate-180 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
                <div class="absolute top-[60px] left-1/2 -translate-x-1/2 w-64 bg-white rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 py-3 border border-gray-100">
                    <a href="/secteurs/boucherie" class="block px-5 py-2.5 text-sm text-[#333333] hover:bg-[#F5F5F5] hover:text-[#13522B] font-medium transition-colors">Boucher Charcutier Traiteur</a>
                    <a href="/secteurs/fromager" class="block px-5 py-2.5 text-sm text-[#333333] hover:bg-[#F5F5F5] hover:text-[#D82F23] font-medium transition-colors">Fromager</a>
                    <a href="/secteurs/boulangerie" class="block px-5 py-2.5 text-sm text-[#333333] hover:bg-[#F5F5F5] hover:text-[#E86B21] font-medium transition-colors">Boulanger Pâtissier</a>
                    <a href="/secteurs/epicerie" class="block px-5 py-2.5 text-sm text-[#333333] hover:bg-[#F5F5F5] hover:text-[#13522B] font-medium transition-colors">Épiceries & Restaurateurs</a>
                    <a href="/secteurs/street-food" class="block px-5 py-2.5 text-sm text-[#333333] hover:bg-[#F5F5F5] hover:text-[#333333] font-medium transition-colors">Street Food</a>
                </div>
            </div>

            <a href="#a-propos" class="nav-link text-white hover:text-[#E86B21] text-sm font-medium transition-colors duration-300">À propos</a>
        </nav>

        <div class="hidden md:flex items-center">
            <a href="/contact" class="bg-[#E86B21] text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-[#d15f1c] transition-colors shadow-md">
                Demander un devis
            </a>
        </div>

        <button id="mobile-menu-btn" class="mobile-btn md:hidden text-white p-2 focus:outline-none transition-colors duration-300" aria-label="Toggle Menu">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 absolute w-full left-0 top-20 shadow-2xl">
        <nav class="flex flex-col px-6 py-6 gap-6">
            <a href="#produits" class="text-[#333333] hover:text-[#13522B] text-lg font-medium transition-colors">Nos Produits</a>
            <a href="#secteurs" class="text-[#333333] hover:text-[#13522B] text-lg font-medium transition-colors">Solutions par Secteur</a>
            <a href="#a-propos" class="text-[#333333] hover:text-[#13522B] text-lg font-medium transition-colors">À propos</a>
            <a href="/contact" class="bg-[#E86B21] text-white px-6 py-4 rounded-xl text-center text-base font-medium mt-4 shadow-lg active:scale-95 transition-transform">
                Demander un devis
            </a>
        </nav>
    </div>
</header>

<style>
    /* Scrolled State Styles */
    #main-header.scrolled {
        background-color: white;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        border-bottom-color: #f3f4f6;
    }

    #main-header.scrolled .logo-text {
        color: #333333;
    }

    #main-header.scrolled .logo-subtext {
        color: rgba(51, 51, 51, 0.6);
    }

    #main-header.scrolled .nav-link {
        color: rgba(51, 51, 51, 0.8);
    }

    #main-header.scrolled .nav-link:hover {
        color: #13522B;
    }

    #main-header.scrolled .mobile-btn {
        color: #333333;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const header = document.getElementById('main-header');
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');

        const handleScroll = () => {
            if (window.scrollY > 50) {
                header?.classList.add('scrolled');
            } else {
                if (menu?.classList.contains('hidden')) {
                    header?.classList.remove('scrolled');
                }
            }
        };

        window.addEventListener('scroll', handleScroll);
        handleScroll();

        if (btn && menu) {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                menu.classList.toggle('hidden');
                
                const svg = btn.querySelector('svg');
                if (menu.classList.contains('hidden')) {
                    svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
                    handleScroll(); 
                } else {
                    svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />';
                    header?.classList.add('scrolled');
                }
            });

            document.addEventListener('click', (e) => {
                if (!menu.classList.contains('hidden') && !menu.contains(e.target as Node) && !btn.contains(e.target as Node)) {
                    menu.classList.add('hidden');
                    const svg = btn.querySelector('svg');
                    if (svg) svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
                    handleScroll();
                }
            });
        }
    });
</script>