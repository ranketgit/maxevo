---
// src/components/Sectors.astro
---

<section class="py-12  bg-white w-full">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
        
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl text-[#333333]  mb-2">
                Vos solutions d'emballage <br class="hidden sm:block" /> par secteur
               
            </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-2 sm:gap-4">
            
            <a href="/secteurs/boucherie" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#13522B] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M12 32h-6"/>
                    <path d="M12 30c0 0 4-8 20-8s20 8 20 8c0 0 4 14-10 18s-20-4-30-18z"/>
                    <path d="M22 24v14M32 22v18M42 24v14"/>
                    <path d="M52 30l8-4v14l-8-4"/>
                    <path d="M55 28v10M58 27v12"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Boucher<br>Charcutier<br>Traiteur</span>
            </a>

            <a href="/secteurs/fromager" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#D82F23] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M14 48l-2-18 36-12 6 28-40 2z"/>
                    <path d="M12 30c0 0 10 4 36-2"/>
                    <circle cx="24" cy="40" r="3"/>
                    <circle cx="36" cy="36" r="2"/>
                    <circle cx="44" cy="42" r="2.5"/>
                    <circle cx="28" cy="32" r="1.5"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Fromager</span>
            </a>

            <a href="/secteurs/boulangerie" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#E86B21] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <rect x="22" y="12" width="20" height="40" rx="8"/>
                    <path d="M22 24c4-2 10 2 20-2"/>
                    <path d="M22 34c4-2 10 2 20-2"/>
                    <path d="M22 44c4-2 10 2 20-2"/>
                    <circle cx="28" cy="18" r="1.5"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Boulanger<br>Pâtissier</span>
            </a>

            <a href="/secteurs/epicerie" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#6B9E78] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M10 28l4-14h36l4 14"/>
                    <path d="M10 28h44v4H10z"/>
                    <path d="M18 14l-2 14M26 14l-1 14M34 14v14M42 14l1 14M50 14l2 14"/>
                    <path d="M14 32v20h36V32"/>
                    <circle cx="18" cy="55" r="2.5"/>
                    <circle cx="46" cy="55" r="2.5"/>
                    <path d="M20 42h10"/>
                    <path d="M40 40c-2 0-2 4 0 4s2-4 0-4z"/>
                    <path d="M18 48h28"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Épiceries<br>Restaurateurs</span>
            </a>

            <a href="/secteurs/street-food" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#F5F5F5] text-[#333333] hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M12 36c0-12 8-20 20-20s20 8 20 20H12z"/>
                    <path d="M14 36v12c0 4 4 6 18 6s18-2 18-6V36"/>
                    <path d="M20 44h24v6H20z"/>
                    <circle cx="26" cy="24" r="1.5"/>
                    <circle cx="36" cy="22" r="1.5"/>
                    <circle cx="44" cy="30" r="1.5"/>
                    <circle cx="30" cy="32" r="1.5"/>
                    <path d="M54 36v16l2 2"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Street<br>Food</span>
            </a>

            <a href="/secteurs/autres" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#333333] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M16 32v20h32V32"/>
                    <path d="M12 32l4-12h32l4 12"/>
                    <path d="M12 32c0 2.2 1.8 4 4 4s4-1.8 4-4 1.8 4 4 4 4-1.8 4-4 1.8 4 4 4 4-1.8 4-4 1.8 4 4 4 4-1.8 4-4"/>
                    <path d="M20 20l-2 12M28 20l-1 12M36 20v12M44 20l1 12M52 20l2 12"/>
                    <path d="M38 40h10v12H38z"/>
                    <circle cx="43" cy="45" r="2.5"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Autres<br>commerces</span>
            </a>

        </div>
    </div>
</section>