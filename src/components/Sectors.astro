---
// src/components/Sectors.astro
---

<section class="py-12 bg-white w-full">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
        
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl text-[#333333] mb-2">
                Vos solutions d'emballage <br class="hidden sm:block" /> par secteur
            </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-2 sm:gap-4">
            
            <a href="/secteurs/cafe-restaurant" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#13522B] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M20 24h20v14c0 5.5-4.5 10-10 10s-10-4.5-10-10V24z"/>
                    <path d="M40 28h4c3.3 0 6 2.7 6 6s-2.7 6-6 6h-4"/>
                    <path d="M12 52h36"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Café /<br>Restaurant</span>
            </a>

            <a href="/secteurs/ecologique" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#D82F23] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M32 12C20 12 12 20 12 32c0 16 20 20 20 20s20-4 20-20c0-12-8-20-20-20z"/>
                    <path d="M32 52V24"/>
                    <path d="M32 36l8-8"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Emballage<br>écologique</span>
            </a>

            <a href="/secteurs/boulangerie" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#E86B21] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <rect x="22" y="12" width="20" height="40" rx="8"/>
                    <path d="M22 24c4-2 10 2 20-2"/>
                    <path d="M22 34c4-2 10 2 20-2"/>
                    <path d="M22 44c4-2 10 2 20-2"/>
                    <circle cx="28" cy="18" r="1.5"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Pâtisserie /<br>Boulangerie</span>
            </a>

            <a href="/secteurs/e-commerce" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#6B9E78] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M14 20l6 24h24l6-24H14z"/>
                    <path d="M24 20v-4c0-4.4 3.6-8 8-8s8 3.6 8 8v4"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">E-commerce</span>
            </a>

            <a href="/secteurs/street-food" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#F5F5F5] text-[#333333] hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M12 36c0-12 8-20 20-20s20 8 20 20H12z"/>
                    <path d="M14 36v12c0 4 4 6 18 6s18-2 18-6V36"/>
                    <path d="M20 44h24v6H20z"/>
                    <circle cx="26" cy="24" r="1.5"/>
                    <circle cx="36" cy="22" r="1.5"/>
                    <circle cx="44" cy="30" r="1.5"/>
                    <circle cx="30" cy="32" r="1.5"/>
                    <path d="M54 36v16l2 2"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Fast-food /<br>Street food</span>
            </a>

            <a href="/secteurs/boissons" class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-[#333333] text-white hover:opacity-90 transition-opacity aspect-square">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mb-4">
                    <path d="M22 24l2 24h16l2-24H22z"/>
                    <path d="M18 24h28"/>
                    <path d="M32 24V10l8-8"/>
                </svg>
                <span class="text-sm md:text-base font-bold leading-snug">Boissons<br>& Jus</span>
            </a>

        </div>
    </div>
</section>