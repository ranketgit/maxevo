---
import '../styles/global.css';


import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { 
	title = "MAXEVO PACKAGING | La qualité dans chaque détail", 
	description = "Maxevo est une entreprise marocaine spécialisée dans les solutions d’emballage alimentaire jetable de haute qualité pour les professionnels de la restauration.",
	image = "/logo.png" // Replace with a real default image later
} = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Maxevo Packaging" />
		<meta name="generator" content={Astro.generator} />
		
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
	</head>
	<body class="bg-maxevo-white text-maxevo-dark flex flex-col min-h-screen">
		<main class="flex-grow">
			<Header />
			<slot />
			<a 
    href="https://wa.me/212660368985?text=Bonjour,%20je%20souhaite%20avoir%20plus%20d'informations." 
    target="_blank" 
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-[9999] hover:-translate-y-1 hover:scale-110 transition-all duration-300 flex items-center justify-center group focus:outline-none drop-shadow-2xl"
    aria-label="Contactez-nous sur WhatsApp"
>
    <!-- Le petit texte qui apparaît au survol -->
    <span class="absolute right-full mr-4 bg-white text-[#333333] text-sm font-medium px-4 py-2 rounded-xl shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap pointer-events-none translate-x-2 group-hover:translate-x-0 hidden md:block border border-gray-100">
        Besoin d'un devis ?
    </span>

    <!-- L'icône WhatsApp officielle en couleurs exactes -->
    <svg viewBox="0 0 24 24" class="w-14 h-14 md:w-16 md:h-16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Bulle verte -->
        <path d="M12.012 2C6.486 2 2 6.486 2 12.012c0 1.76.452 3.42 1.258 4.887L2 22l5.253-1.22A9.972 9.972 0 0012.012 22c5.526 0 10.012-4.486 10.012-10.012S17.538 2 12.012 2z" fill="#25D366"/>
        <!-- Téléphone blanc -->
        <path d="M16.516 14.283c-.226-.113-1.334-.66-1.54-.736-.206-.076-.356-.113-.506.113-.15.226-.583.736-.714.887-.13.15-.262.17-.488.056-.226-.113-.952-.35-1.815-1.12-.67-.6-1.12-1.342-1.25-1.568-.13-.226-.014-.348.1-.46.1-.1.226-.264.338-.396.113-.13.15-.225.226-.376.075-.15.038-.282-.019-.395-.056-.113-.506-1.223-.694-1.674-.183-.44-.37-.38-.506-.388-.13-.007-.28-.007-.43-.007-.15 0-.395.056-.6.282-.207.226-.79.772-.79 1.884 0 1.11.808 2.185.92 2.336.113.15 1.593 2.43 3.86 3.41.54.232.96.37 1.288.475.542.173 1.036.148 1.425.09.434-.065 1.334-.545 1.522-1.073.188-.527.188-.98.13-1.073-.055-.094-.206-.15-.432-.263z" fill="#FFF"/>
    </svg>
</a>
			<Footer />
		</main>
	</body>
</html>