---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout 
    title="Contact & Devis | MAXEVO PACKAGING" 
    description="Contactez Maxevo Packaging pour demander un devis personnalisé ou pour toute information sur nos solutions d'emballage alimentaire."
>
    <Hero 
        title="Contactez-nous"
        description="Prêt à faire passer votre emballage au niveau supérieur ? Remplissez le formulaire ci-dessous pour demander un devis gratuit ou posez-nous vos questions. Notre équipe vous répondra dans les plus brefs délais."
       
        bgImage="/bg.jpeg"
    />

    <section class="py-16 md:py-24 bg-white w-full">
        <div class="container mx-auto px-4 md:px-8 max-w-7xl">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
                
                <div class="flex flex-col">
                    <span class="text-[#13522B] font-bold text-sm md:text-base tracking-widest uppercase mb-4">
                        Gardons le contact
                    </span>
                    <h2 class="text-3xl md:text-4xl font-black text-[#333333] mb-8 leading-tight tracking-tight">
                        Discutons de votre projet d'<span class="text-[#E86B21]">emballage.</span>
                    </h2>
                    <p class="text-[#333333] opacity-80 text-lg mb-12 leading-relaxed">
                        Que vous ayez besoin d'un devis pour un volume important ou de conseils sur les meilleurs matériaux pour vos plats, nous sommes là pour vous guider.
                    </p>

                    <div class="flex flex-col gap-8">
                        <div class="flex items-start gap-4 group">
                            <div class="w-14 h-14 rounded-2xl bg-[#F9F9F9] flex items-center justify-center text-[#13522B] shrink-0 group-hover:bg-[#13522B] group-hover:text-white transition-colors duration-300">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-[#333333] mb-1">Notre bureau</h3>
                                <p class="text-[#333333] opacity-70 leading-relaxed">
                                    Rue Bachir Ibrahimi Mamounia<br/>
                                    Centre B3 9 ETG 5<br/>
                                    20000 Casablanca, Maroc
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4 group">
                            <div class="w-14 h-14 rounded-2xl bg-[#F9F9F9] flex items-center justify-center text-[#13522B] shrink-0 group-hover:bg-[#13522B] group-hover:text-white transition-colors duration-300">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-[#333333] mb-1">Téléphone</h3>
                                <a href="tel:+212660368985" class="text-[#333333] opacity-70 hover:text-[#E86B21] hover:opacity-100 transition-colors block">
                                    +212 660-368985
                                </a>
                            </div>
                        </div>

                        <div class="flex items-start gap-4 group">
                            <div class="w-14 h-14 rounded-2xl bg-[#F9F9F9] flex items-center justify-center text-[#13522B] shrink-0 group-hover:bg-[#13522B] group-hover:text-white transition-colors duration-300">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-[#333333] mb-1">Email</h3>
                                <a href="mailto:contact@maxevo.ma" class="text-[#333333] opacity-70 hover:text-[#E86B21] hover:opacity-100 transition-colors block">
                                    contact@maxevo.ma
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[2rem] border border-gray-100 shadow-xl">
                    <h3 class="text-2xl font-bold text-[#333333] mb-6">Demander un devis</h3>
                    
                    <form action="https://formsubmit.co/contact@maxevo.ma" method="POST" class="flex flex-col gap-5">
                        
                        <input type="text" name="_honey" style="display:none">
                        <input type="hidden" name="_captcha" value="false">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="flex flex-col">
                                <label for="name" class="text-sm font-medium text-[#333333] mb-2">Nom complet *</label>
                                <input type="text" name="name" id="name" required class="px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:border-[#13522B] focus:ring-1 focus:ring-[#13522B] transition-colors w-full" placeholder="Jean Dupont">
                            </div>
                            <div class="flex flex-col">
                                <label for="company" class="text-sm font-medium text-[#333333] mb-2">Entreprise</label>
                                <input type="text" name="company" id="company" class="px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:border-[#13522B] focus:ring-1 focus:ring-[#13522B] transition-colors w-full" placeholder="Nom de votre restaurant">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="flex flex-col">
                                <label for="email" class="text-sm font-medium text-[#333333] mb-2">Email *</label>
                                <input type="email" name="email" id="email" required class="px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:border-[#13522B] focus:ring-1 focus:ring-[#13522B] transition-colors w-full" placeholder="jean@exemple.com">
                            </div>
                            <div class="flex flex-col">
                                <label for="phone" class="text-sm font-medium text-[#333333] mb-2">Téléphone *</label>
                                <input type="tel" name="phone" id="phone" required class="px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:border-[#13522B] focus:ring-1 focus:ring-[#13522B] transition-colors w-full" placeholder="+212 600 000 000">
                            </div>
                        </div>

                        <div class="flex flex-col">
                            <label for="subject" class="text-sm font-medium text-[#333333] mb-2">Objet de votre demande *</label>
                            <select name="_subject" id="subject" required class="px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:border-[#13522B] focus:ring-1 focus:ring-[#13522B] transition-colors w-full text-[#333333]">
                                <option value="Demande de devis">Demande de devis</option>
                                <option value="Information sur les produits">Information sur les produits</option>
                                <option value="Autre demande">Autre demande</option>
                            </select>
                        </div>

                        <div class="flex flex-col">
                            <label for="message" class="text-sm font-medium text-[#333333] mb-2">Message *</label>
                            <textarea name="message" id="message" rows="4" required class="px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:border-[#13522B] focus:ring-1 focus:ring-[#13522B] transition-colors w-full resize-none" placeholder="Précisez les produits recherchés, les quantités, etc."></textarea>
                        </div>

                        <button type="submit" class="bg-[#E86B21] text-white px-8 py-4 rounded-xl font-medium hover:bg-[#d15f1c] transition-colors flex items-center justify-center gap-3 group mt-2 shadow-lg w-full">
                            Envoyer la demande
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                            </svg>
                        </button>
                        
                    </form>
                </div>

            </div>
        </div>
    </section>
</Layout>