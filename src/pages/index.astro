---
import Layout from '../layouts/Layout.astro';

import Hero from '../components/Hero.astro';
import Sectors from '../components/Sectors.astro';
import TrustedPartner from '../components/TrustedPartner.astro';
import About from '../components/About.astro';
import Process from '../components/Process.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';

---

<Layout>
	<Hero 
        title="Personnalisez Vos Emballages"
        description="Créez une solution d'emballage sur mesure, adaptée à vos besoins spécifiques. Chez Maxevo, nous nous engageons à fournir des produits fiables et haut de gamme."
        primaryBtnText="Nos Produits"
        primaryBtnLink="/produits"
        secondaryBtnText="Demander un devis"
        secondaryBtnLink="/contact"
        bgImage="/path-to-your-boxes-image.png"
    />
	<Sectors />
	<TrustedPartner />
	<About />
	<Process />
	<FeaturedProducts />
</Layout>
