---
// src/pages/produits/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import AddToCart from '../../components/AddToCart.jsx';

const { slug } = Astro.params;

const query = `
  query GetProductBySlug($id: ID!) {
    product(id: $id, idType: SLUG) {
      name
      slug
      sku
      shortDescription(format: RAW)
      description(format: RAW)
      image {
        sourceUrl
      }
      productCategories {
        nodes {
          name
        }
      }
    }
  }
`;

let product = null;

try {
    const response = await fetch("https://admin.maxevopackaging.ma/graphql", {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
            query, 
            variables: { id: slug } 
        }),
    });
    
    const json = await response.json();
    product = json.data?.product;
} catch (error) {
    console.error("Erreur GraphQL SSR:", error);
}

// 5. If WordPress doesn't find the product, return a 404 immediately
if (!product) {
    return Astro.redirect('/404');
}

// Variables de secours
const categoryName = product.productCategories?.nodes?.[0]?.name || "Général";
const imageUrl = product.image?.sourceUrl || "/placeholder.jpg";
const miniDesc = product.shortDescription || "";
const fullDesc = product.description || "Détails non spécifiés";

const productForCart = {
    ...product,
    sku: product.sku || product.slug 
};
---

<Layout title={`${product.name} | MAXEVO PACKAGING`} description={miniDesc}>
    <Header />
    
    <section class="pt-32 pb-16 md:pt-40 md:pb-24 bg-white w-full min-h-screen">
        <div class="container mx-auto px-4 md:px-8 max-w-6xl">
            <!-- Breadcrumbs -->
            <div class="flex items-center gap-2 text-sm text-[#333333] opacity-60 mb-8">
                <a href="/" class="hover:text-[#13522B] transition-colors">Accueil</a>
                <span>/</span>
                <a href="/#produits" class="hover:text-[#13522B] transition-colors">Produits</a>
                <span>/</span>
                <span class="font-medium opacity-100">{product.name}</span>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
                <!-- Image -->
                <div class="w-full aspect-[4/5] md:aspect-square bg-[#F9F9F9] rounded-[2rem] border border-gray-100 overflow-hidden flex items-center justify-center p-8">
                    <img 
                        src={imageUrl} 
                        alt={product.name} 
                        class="w-full h-full object-contain mix-blend-multiply"
                    />
                </div>

                <!-- Info -->
                <div class="flex flex-col">
                    <span class="text-[#13522B] font-bold text-sm md:text-base tracking-widest uppercase mb-3">
                        {categoryName}
                    </span>
                    
                    <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-[#333333] mb-6 tracking-tight leading-tight">
                        {product.name}
                    </h1>
                    
                    <p class="text-lg md:text-xl text-[#333333] opacity-80 mb-10 leading-relaxed font-light">
                        {miniDesc}
                    </p>

                    <div class="bg-[#F9F9F9] rounded-2xl p-6 md:p-8 mb-10 border border-gray-100 shadow-sm">
                        <h3 class="text-lg font-bold text-[#333333] mb-4">Spécifications</h3>
                        <div class="flex flex-col gap-4">
                            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
                                <span class="text-[#333333] opacity-70 whitespace-nowrap">Détails / Colisage</span>
                                <span class="font-medium text-[#333333] sm:text-right" set:html={fullDesc}></span>
                            </div>
                        </div>
                    </div>

                    <AddToCart client:load product={productForCart} />
                </div>
            </div>
        </div>
    </section>
</Layout>