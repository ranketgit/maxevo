---
// src/pages/secteurs/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const { slug } = Astro.params;

// Query updated to support pagination variables ($first, $after)
const query = `
  query GetAllData($first: Int!, $after: String) {
    productCategories(first: 50, where: { hideEmpty: false }) {
      nodes {
        name
        slug
      }
    }
    products(first: $first, after: $after) {
      pageInfo {
        hasNextPage
        endCursor
      }
      nodes {
        ... on Product {
          name
          slug
          shortDescription(format: RAW)
          image {
            sourceUrl
          }
          productCategories {
            nodes {
              name
              slug
            }
          }
        }
      }
    }
  }
`;

let allCategories = [];
let allProducts = [];
let hasNextPage = true;
let endCursor = null;

try {
    // Keep fetching until WordPress says there are no more products
    while (hasNextPage) {
        const response = await fetch("https://admin.maxevopackaging.ma/graphql", {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                query,
                variables: {
                    first: 100,
                    after: endCursor
                }
            }),
        });
        
        const json = await response.json();
        
        // We only need to set categories on the first loop
        if (!endCursor) {
            allCategories = json.data?.productCategories?.nodes || [];
        }

        // Add the new batch to our master product list
        const newProducts = json.data?.products?.nodes || [];
        allProducts = [...allProducts, ...newProducts];

        // Update pagination trackers for the next loop
        hasNextPage = json.data?.products?.pageInfo?.hasNextPage || false;
        endCursor = json.data?.products?.pageInfo?.endCursor || null;
    }
} catch (error) {
    console.error("Erreur GraphQL SSR Secteurs:", error);
}

// FIX 1: THE 404 ERROR (Matches hotel to hôtel, e-commerce to ecommerce, etc.)
const category = allCategories.find(c => 
    c.slug === slug || 
    c.slug.replace(/-/g, '') === slug.replace(/-/g, '')
);

if (!category) {
    return Astro.redirect('/404');
}

// FIX 2: THE "ALL PRODUCTS" ERROR (Manual filtering from the master list)
const products = allProducts.filter((product) => {
    const productCats = product.productCategories?.nodes || [];
    return productCats.some(cat => cat.slug === category.slug);
});

// Sector icons updated with the new Hôtel SVG
const sectorIcons = {
    "cafe-restaurant": '<path d="M20 24h20v14c0 5.5-4.5 10-10 10s-10-4.5-10-10V24z"/><path d="M40 28h4c3.3 0 6 2.7 6 6s-2.7 6-6 6h-4"/><path d="M12 52h36"/>',
    "ecologique": '<path d="M32 12C20 12 12 20 12 32c0 16 20 20 20 20s20-4 20-20c0-12-8-20-20-20z"/><path d="M32 52V24"/><path d="M32 36l8-8"/>',
    "boulangerie": '<rect x="22" y="12" width="20" height="40" rx="8"/><path d="M22 24c4-2 10 2 20-2"/><path d="M22 34c4-2 10 2 20-2"/><path d="M22 44c4-2 10 2 20-2"/><circle cx="28" cy="18" r="1.5"/>',
    "hotel": '<path d="M16 52V12a4 4 0 014-4h24a4 4 0 014 4v40"/><path d="M12 52h40"/><path d="M28 52V40a4 4 0 018 0v12"/><rect x="24" y="18" width="5" height="5"/><rect x="35" y="18" width="5" height="5"/><rect x="24" y="28" width="5" height="5"/><rect x="35" y="28" width="5" height="5"/>',
    "street-food": '<path d="M12 36c0-12 8-20 20-20s20 8 20 20H12z"/><path d="M14 36v12c0 4 4 6 18 6s18-2 18-6V36"/><path d="M20 44h24v6H20z"/><circle cx="26" cy="24" r="1.5"/><circle cx="36" cy="22" r="1.5"/><circle cx="44" cy="30" r="1.5"/><circle cx="30" cy="32" r="1.5"/><path d="M54 36v16l2 2"/>',
    "boissons": '<path d="M22 24l2 24h16l2-24H22z"/><path d="M18 24h28"/><path d="M32 24V10l8-8"/>'
};

// Ensure the icon loads even if there is a hyphen mismatch
const currentIcon = sectorIcons[category.slug] || sectorIcons[slug] || '<circle cx="32" cy="32" r="20" fill="none" stroke="currentColor" stroke-width="2.5"/>';
---

<Layout title={`${category.name || 'Secteur'} | MAXEVO PACKAGING`} description={`Découvrez nos solutions d'emballage pour ${category.name}.`}>
    <Header />
    
    <section class="pt-32 pb-16 md:pt-40 md:pb-24 bg-[#F9F9F9] w-full min-h-screen">
        <div class="container mx-auto px-4 md:px-8 max-w-7xl">
            
            <div class="flex items-center gap-2 text-sm text-[#333333] opacity-60 mb-8">
                <a href="/" class="hover:text-[#13522B] transition-colors">Accueil</a>
                <span>/</span>
                <span>Secteurs</span>
                <span>/</span>
                <span class="font-medium opacity-100">{category.name || 'Secteur'}</span>
            </div>

            <div class="flex flex-col md:flex-row items-start md:items-center gap-6 mb-16">
                <div class="w-20 h-20 bg-[#13522B] text-white rounded-2xl flex items-center justify-center shrink-0 shadow-lg">
                    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10">
                        <Fragment set:html={currentIcon} />
                    </svg>
                </div>
                <div>
                    <h1 class="text-4xl md:text-5xl font-black text-[#333333] tracking-tight mb-2">
                        {category.name || 'Catégorie'}
                    </h1>
                    <p class="text-lg text-[#333333] opacity-70">
                        {products.length} {products.length > 1 ? "produits disponibles" : "produit disponible"}
                    </p>
                </div>
            </div>

            {products.length > 0 ? (
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
                    {products.map((product) => {
                        const productCategoryName = product.productCategories?.nodes?.[0]?.name || category.name || "Général";
                        const imageUrl = product.image?.sourceUrl || "/placeholder.jpg";
                        const desc = product.shortDescription || "";

                        return (
                            <a href={`/produits/${product.slug}`} class="bg-white p-4 rounded-[1.5rem] shadow-sm hover:shadow-xl border border-gray-100 transition-all duration-300 group focus:outline-none flex flex-col h-full">
                                <div class="w-full aspect-[4/5] bg-[#F9F9F9] rounded-xl mb-5 overflow-hidden transition-colors pointer-events-none">
                                    <img 
                                        src={imageUrl} 
                                        alt={product.name} 
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                        loading="lazy"
                                    />
                                </div>
                                <span class="text-xs text-[#13522B] font-bold uppercase tracking-widest mb-2 block">{productCategoryName}</span>
                                <h3 class="text-xl font-bold text-[#333333] mb-2 group-hover:text-[#E86B21] transition-colors line-clamp-1">{product.name}</h3>
                                <div class="text-sm font-light text-[#333333] opacity-70 line-clamp-2 mt-auto" set:html={desc}></div>
                            </a>
                        );
                    })}
                </div>
            ) : (
                <div class="w-full py-24 flex flex-col items-center justify-center bg-white rounded-[2rem] border border-gray-100 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                    <h3 class="text-2xl font-bold text-[#333333] mb-2">Aucun produit</h3>
                    <p class="text-[#333333] opacity-60">Nous n'avons pas encore ajouté de produits dans cette catégorie.</p>
                </div>
            )}

        </div>
    </section>
</Layout>